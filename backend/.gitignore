cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*.pyc
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/

# Environment secrets
.env
.env.local
.env.*.local

# Testing
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.next/
frontend/build/

# IDE
.vscode/settings.json
.idea/
.DS_Store

# Celery
celerybeat-schedule
celerybeat.pid
EOF